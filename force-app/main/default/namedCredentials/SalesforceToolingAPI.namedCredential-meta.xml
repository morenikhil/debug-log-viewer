<?xml version="1.0" encoding="UTF-8"?>
<!--
    Named Credential: SalesforceToolingAPI
    ───────────────────────────────────────
    Authentication: OAuth 2.0 — "Named Principal" flow using a Connected App
    configured in Setup > App Manager (with Tooling API scope).

    Steps:
      1. Create a Connected App in your sandbox with:
           - OAuth Scopes: api, refresh_token, offline_access
      2. In Setup > Security > Named Credentials, create this record and supply
         the Consumer Key/Secret from the Connected App.
      3. The Callout URL must point to YOUR sandbox My Domain URL.

    Replace https://YOUR-SANDBOX.my.salesforce.com with your actual sandbox URL.
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>SalesforceToolingAPI</label>
  <endpoint>https://YOUR-SANDBOX.my.salesforce.com</endpoint>
  <principalType>NamedUser</principalType>
  <protocol>NoAuthentication</protocol>
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
</NamedCredential>
